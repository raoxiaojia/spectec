;;
;; some tricky definitions to test the transformations
;;

relation HasSize: nat |- nat
relation TestNestedIter: nat*** |- nat**

var n : nat
var m : nat

rule TestNestedIter:
  n**+ |- m*+
  -- if (|n*| = m)*+


;;
;;  Totalize testing some tricky totalize functionality
;;

def $t_totalize(nat) : nat hint(totalize)
def $t_totalize(3) = 5
def $t_totalize(10) = 20

def $t_totalize2(nat) : nat hint(totalize)
def $t_totalize2(1) = 2
def $t_totalize2(n) = $t_totalize(n)

def $t_totalize3(nat) : nat hint(totalize)
def $t_totalize3(n) = $($t_totalize(n) + $t_totalize2($t_totalize(n)))